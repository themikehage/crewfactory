## Modelo de Datos

### `PipelineDefinition` (`definition.json`)

```typescript
interface PipelineDefinition {
  id: string;
  name: string;
  description: string;
  version: number;
  stages: PipelineStage[];
  createdAt: string;
  updatedAt: string;
}

type PipelineStage = ScriptStage | AgentStage;

interface ScriptStageBase {
  id: string;          // único dentro del pipeline — "lint", "build"
  name: string;
  description: string;
  type: "script";
  script: string;      // nombre de archivo en scripts/ O bash inline
  outputSchema?: OutputField[];
  timeoutMs?: number;  // default: 120_000 (2 min)
}

interface AgentStage {
  id: string;
  name: string;
  description: string;
  type: "agent";
  agentId?: string;    // null → sesión temporal con modelo default del usuario
  prompt: string;
  outputSchema?: OutputField[];
  timeoutMs?: number;  // default: 300_000 (5 min)
}

interface OutputField {
  name: string;
  type: "string" | "number" | "boolean" | "json";
  description: string;
}
```

### `PipelineRun` (`runs/{runId}/run.json`)

```typescript
interface PipelineRun {
  id: string;
  pipelineId: string;
  status: "running" | "completed" | "failed";
  triggeredBy: "manual" | "agent";
  startedAt: string;
  finishedAt?: string;
  stageResults: StageResult[];
  error?: { stageId: string; message: string };
}

interface StageResult {
  stageId: string;
  status: "pending" | "running" | "completed" | "failed";
  sessionId?: string;      // solo para stages de tipo agent
  output: Record<string, unknown>;
  rawOutput: string;
  startedAt?: string;
  finishedAt?: string;
  tokensIn?: number;       // solo para agent stages
  tokensOut?: number;
}
```

