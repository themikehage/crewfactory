Scripts en `scripts/`:
```bash
# lint.sh
#!/bin/bash
set -e
pnpm lint 2>&1 | tee $PIPELINE_ARTIFACTS_DIR/lint.log
ERRORS=$(cat $PIPELINE_ARTIFACTS_DIR/lint.log | grep "error" | wc -l)
echo '---OUTPUT---'
echo "{\"passed\": $([ $ERRORS -eq 0 ] && echo true || echo false), \"errors\": $ERRORS}"
echo '---END OUTPUT---'
```

