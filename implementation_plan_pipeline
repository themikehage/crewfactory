## Agent-First Integration

### `manage_factory` — contrato `pipelines`

```typescript
// factory-contracts.ts
pipelines: {
  entity: "pipelines",
  description: "Deterministic linear execution pipelines with script and agent stages",
  actions: {
    get: {
      // id omitido → lista todos
      // id = "pipeline-id" → definición
      // id = "pipeline-id/runs" → historial de runs
      // id = "pipeline-id/runs/run-id" → detalle de un run
      params: { id: { type: "string", required: false } }
    },
    upsert: {
      params: {
        id:          { type: "string",  required: true },
        name:        { type: "string",  required: true },
        description: { type: "string",  required: false },
        stages:      { type: "array",   required: true,
                       description: "Array of PipelineStage objects (type: script|agent)" },
        scripts:     { type: "object",  required: false,
                       description: "Map of script filename → bash content" }
      }
    },
    delete: {
      params: { id: { type: "string", required: true } }
    }
  }
}
```

